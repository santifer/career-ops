[Unit]
Description=Yash Pipeline Telegram Listener
After=network-online.target
Wants=network-online.target

[Service]
Type=notify
NotifyAccess=all
WorkingDirectory=/yash-superClaudeHuman/projects/yash-ai-automation-career
EnvironmentFile=/etc/yash-pipeline/agent.env
ExecStart=/usr/bin/env node services/telegram-listener.mjs
Restart=on-failure
RestartSec=5
WatchdogSec=90
TimeoutStartSec=30
TimeoutStopSec=45
MemoryMax=256M
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target

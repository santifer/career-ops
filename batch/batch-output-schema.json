{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "career-ops batch worker result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "id",
    "report_num",
    "company",
    "role",
    "score",
    "pdf",
    "report",
    "error"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["completed", "failed", "prepared"]
    },
    "id": {
      "type": ["string", "integer", "null"]
    },
    "report_num": {
      "type": ["string", "null"]
    },
    "company": {
      "type": ["string", "null"]
    },
    "role": {
      "type": ["string", "null"]
    },
    "score": {
      "type": ["number", "string", "null"]
    },
    "pdf": {
      "type": ["string", "null"]
    },
    "report": {
      "type": ["string", "null"]
    },
    "error": {
      "type": ["string", "null"]
    }
  }
}

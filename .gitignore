# Personal data (user fills these)
cv.md
data/applications.md
data/apply-queue.json
data/local-enrichments.json
data/answer-cache.json
data/.answer-cache-*.tmp
data/pipeline.md
data/scan-history.tsv
data/parser-output/**/*.json
!data/parser-output/.gitkeep
!data/parser-output/**/.gitkeep
reports/*.md
!reports/.gitkeep
output/*
!output/.gitkeep
batch/logs/*
!batch/logs/.gitkeep
batch/batch-state.tsv
batch/batch-input.tsv
batch/tracker-additions/**/*.tsv
!batch/tracker-additions/.gitkeep
jds/*
!jds/.gitkeep

# Writing samples (user's personal files — never committed)
writing-samples/*
!writing-samples/README.md

# User config and customization (never auto-updated)
config/profile.yml
portals.yml
modes/_profile.md
.update-dismissed
.update-lock

# Secrets (never commit — use .env.example as template)
.env
career_ops_signing_key_private.json

# Portal credentials (auto-generated passwords, never commit)
data/portal-credentials.json

# Persistent browser profiles (cookies, sessions per portal host)
.browser-profiles/

# Generated
.resolved-prompt-*
.playwright-mcp/
node_modules/
bun.lock

# OS
.DS_Store
*.mov
*.mp4

# Claude Code local
.claude/settings.local.json
.claude/memory/
.claude/scheduled_tasks.lock
career-dashboard
package-lock.json


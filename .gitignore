# Personal data (user fills these)
data/applications.md
data/pipeline.md
data/scan-history.tsv
reports/*.md
!reports/.gitkeep
output/*
!output/.gitkeep
batch/logs/*
!batch/logs/.gitkeep
batch/batch-state.tsv
batch/batch-input.tsv
batch/tracker-additions/*.tsv
!batch/tracker-additions/.gitkeep
jds/*
!jds/.gitkeep

# User config and customization (never auto-updated)
config/profile.yml
portals.yml
modes/_profile.md
.update-dismissed
.update-lock

# Generated
.resolved-prompt-*
node_modules/

# OS
.DS_Store
*.mov
*.mp4

# Claude Code local
.claude/settings.local.json
.claude/memory/
career-dashboard

# ── Environment secrets — NEVER commit these ────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
*.crt
secrets.json

# User-supplied resume + generated personal artifacts (contain PII)
cv.md
article-digest.md
data/follow-ups.md
# story-bank.md accumulates personal STAR+R stories — never commit
# (the empty template lives at templates/story-bank.template.md and
# is copied into interview-prep/story-bank.md on first launch)
interview-prep/story-bank.md
interview-prep/*.md
!interview-prep/.gitkeep

# Backups + transient state
backups/
.dashboard.log
.cache/
tmp/
.tmp/

# Build / release artifacts (we don't track binaries; CI publishes them)
dist/
build/
*.exe
career-ops.tar.gz

# OAuth tokens & local caches with PII
data/gmail-tokens.json
data/gmail-cache.json
data/autopilot-log.json
data/autopilot-manual.json
data/dash-debug.json
data/high-paying-queue.json
data/high-paying-queue.md
data/apply-queue.md
data/pipeline.md.bak

# Worktrees + agent scratch
.claude/worktrees/
.claude/scheduled_tasks.lock
.conductor/mistakes-read
dashboard-web/.conductor/

# Test scratch
tests/__fixtures__/tmp/

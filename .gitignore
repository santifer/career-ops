# Personal data (user fills these)
.env
.env.local
.env.*
!.env.example
!.env.*.example
/data/
!/data/.gitkeep
dashboard.log
reports/*.md
!reports/.gitkeep
output/*
!output/.gitkeep
batch/logs/*
!batch/logs/.gitkeep
batch/batch-state.tsv
batch/batch-input.tsv
batch/tracker-additions/*.tsv
!batch/tracker-additions/.gitkeep
jds/*
!jds/.gitkeep

# User config and customization (never auto-updated)
config/profile.yml
portals.yml
modes/_profile.md
.update-dismissed
.update-lock

# Generated
.resolved-prompt-*
node_modules/

# OS
.DS_Store
*.mov
*.mp4

# Claude Code local
.claude/settings.local.json
.claude/memory/
career-dashboard
package-lock.json

# Personal CV and instructions (user-specific, never push)
cv.md
INSTRUCTIONS.md

# Auto-generated scratch scripts (may contain hardcoded personal data)
scratch/
!scratch/fetch-indeed-job.mjs
!scratch/ingest-lever.mjs
scratch-*.mjs
scratch-*.cjs
# But keep the core scanner tracked
!scratch-scan.mjs

.vercel

# Security/log hygiene
*.pem
*.key
*.p12
*.pfx
dashboard-v2/vercel_deploy_output.log

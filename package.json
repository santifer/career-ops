    "normalize": "node normalize-statuses.mjs",
    "dedup": "node dedup-tracker.mjs",
    "merge": "node merge-tracker.mjs",
    "pdf": "node generate-pdf.mjs",
    "sync-check": "node cv-sync-check.mjs",
    "update:check": "node update-system.mjs check",
    "update": "node update-system.mjs apply",
    "rollback": "node update-system.mjs rollback",
    "liveness": "node check-liveness.mjs",
    "cli": "node cli/bin/career-ops-cli.js",
    "cli:evaluate": "node cli/bin/career-ops-cli.js evaluate",
    "cli:tracker": "node cli/bin/career-ops-cli.js tracker",
    "cli:pdf": "node cli/bin/career-ops-cli.js pdf",
    "cli:doctor": "node cli/bin/career-ops-cli.js doctor",
    "cli:scan": "node cli/bin/career-ops-cli.js scan",
    "cli:batch": "node cli/bin/career-ops-cli.js batch",
    "cli:apply": "node cli/bin/career-ops-cli.js apply",
    "cli:contact": "node cli/bin/career-ops-cli.js contact",
    "cli:deep": "node cli/bin/career-ops-cli.js deep",
    "cli:training": "node cli/bin/career-ops-cli.js training",
    "cli:project": "node cli/bin/career-ops-cli.js project",
    "cli:add-companies": "node cli/bin/career-ops-cli.js add-companies",
    "cli:job-search": "node cli/bin/career-ops-cli.js job-search"

{
  "name": "career-ops",
  "version": "1.20.0",
  "description": "AI-powered job search pipeline — works with any AI coding CLI (Claude Code, OpenCode, Gemini, Codex, Qwen)",
  "private": true,
  "scripts": {
    "doctor": "python -m scripts.python.admin.doctor",
    "or": "python -m scripts.python.other.openrouter_runner",
    "or:scan": "python -m scripts.python.other.openrouter_runner scan",
    "or:pipeline": "python -m scripts.python.other.openrouter_runner pipeline",
    "or:eval": "python -m scripts.python.other.openrouter_runner evaluate",
    "or:apply": "python -m scripts.python.other.openrouter_runner apply",
    "verify": "python -m scripts.python.tracker.verify_pipeline",
    "normalize": "python -m scripts.python.tracker.normalize_statuses",
    "dedup": "python -m scripts.python.tracker.dedup_tracker",
    "merge": "python -m scripts.python.tracker.merge_tracker",
    "reconcile": "python -m scripts.python.tracker.reconcile_pipeline",
    "pdf": "python -m scripts.python.cv.generate_pdf",
    "img-to-pdf": "python -m scripts.python.other.img_to_pdf",
    "cover-letter": "python -m scripts.python.cv.generate_cover_letter --payload",
    "cv:verify-facts": "python -m scripts.python.cv.verify_cv_facts",
    "sync-check": "python -m scripts.python.admin.cv_sync_check",
    "update:check": "python -m scripts.python.admin.update_system check",
    "update:test": "node scripts/archived-js/updater-migration-tests.mjs",
    "update": "python -m scripts.python.admin.update_system apply",
    "rollback": "python -m scripts.python.admin.update_system rollback",
    "liveness": "python -m scripts.python.scanner.check_liveness",
    "extract": "python -m scripts.python.pipeline.browser_extract",
    "scan": "python -m scripts.python.scanner.scan",
    "scan:full": "python -m scripts.python.scanner.scan_ats_full",
    "scan:seeds": "python -m scripts.python.scanner.scan_ats_full --seeds yc,a16z",
    "scan:yc": "python -m scripts.python.scanner.scan_ats_full --seeds yc",
    "validate:portals": "python -m scripts.python.admin.validate_portals",
    "verify:portals": "python -m scripts.python.admin.verify_portals",
    "tracker": "node scripts/archived-js/tracker.mjs",
    "find": "python -m scripts.python.tracker.find",
    "patterns": "python -m scripts.python.admin.analyze_patterns",
    "upskill": "python -m scripts.python.admin.upskill",
    "add": "python -m scripts.python.tracker.add_entry",
    "reposts": "python -m scripts.python.tracker.detect_reposts",
    "invite-match": "python -m scripts.python.tracker.invite_match",
    "paste-reply": "python -m scripts.python.reply.paste_reply",
    "gemini:eval": "python -m scripts.python.evaluation.gemini_eval",
    "ollama:eval": "python -m scripts.python.evaluation.ollama_eval",
    "openai:eval": "python -m scripts.python.evaluation.openai_eval",
    "openai:tailor": "python -m scripts.python.evaluation.openai_tailor",
    "eval:golden": "python -m scripts.python.evaluation.eval_golden",
    "star": "python -m scripts.python.interview.match_star",
    "archive": "python -m scripts.python.other.archive_posting",
    "prepare:application": "python -m scripts.python.other.prepare_application",
    "build:dashboard": "python -m scripts.python.export.build_dashboard",
    "serve:dashboard": "cd dashboard && go run . --path ..",
    "postinstall": "npx playwright install chromium --with-deps || npx playwright install chromium --with-deps",
    "manifesto": "python -m scripts.python.admin.manifesto"
  },
  "keywords": [
    "ai",
    "job-search",
    "claude-code",
    "opencode",
    "career",
    "career-ops",
    "careerops",
    "automation"
  ],
  "author": "Santiago Fernández de Valderrama <hi@santifer.io> (https://santifer.io)",
  "homepage": "https://santifer.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/santifer/career-ops"
  },
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^17.0.0",
    "js-yaml": "^4.1.1",
    "playwright": "1.61.1"
  }
}

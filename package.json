{
  "name": "career-ops",
  "version": "1.7.0",
  "description": "AI-powered job search pipeline built on Claude Code",
  "scripts": {
    "doctor": "node doctor.mjs",
    "verify": "node verify-pipeline.mjs",
    "normalize": "node normalize-statuses.mjs",
    "dedup": "node dedup-tracker.mjs",
    "merge": "node merge-tracker.mjs",
    "pdf": "node generate-pdf.mjs",
    "sync-check": "node cv-sync-check.mjs",
    "update:check": "node update-system.mjs check",
    "update": "node update-system.mjs apply",
    "rollback": "node update-system.mjs rollback",
    "liveness": "node check-liveness.mjs",
    "scan": "node scan.mjs",
    "gemini:eval": "node gemini-eval.mjs",
    "test:dashboard": "playwright test --config=tests/playwright.config.mjs",
    "test:dashboard:ui": "playwright test --config=tests/playwright.config.mjs --ui",
    "test:dashboard:install": "playwright install chromium",
    "lighthouse": "lhci autorun",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format .",
    "test:unit": "node --test tests/unit/*.mjs",
    "dashboard": "node dashboard-server.mjs",
    "dashboard:dev": "NODE_ENV=development node dashboard-server.mjs",
    "outreach": "node scripts/log-touch.mjs --summary-json",
    "outreach:due": "node scripts/log-touch.mjs --due",
    "outreach:log": "node scripts/log-touch.mjs",
    "outreach:recommend": "node scripts/recommend-next-action.mjs",
    "outreach:status": "node scripts/outreach-status.mjs",
    "outreach:intel": "node scripts/refresh-intel.mjs",
    "outreach:import": "node scripts/import-contacts.mjs",
    "outreach:li-activity": "node scripts/log-linkedin-activity.mjs",
    "skill-ingest": "node scripts/skill-ingest.mjs",
    "skill-ingest:dry-run": "node scripts/skill-ingest.mjs --dry-run",
    "skill-ingest:apply": "node scripts/skill-ingest.mjs --apply"
  },
  "keywords": [
    "ai",
    "job-search",
    "claude-code",
    "career",
    "automation"
  ],
  "author": "Santiago Fernández de Valderrama <hi@santifer.io> (https://santifer.io)",
  "homepage": "https://santifer.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/santifer/career-ops"
  },
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^2.3.0",
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^16.4.5",
    "js-yaml": "^4.1.1",
    "marked": "^18.0.3",
    "nodemailer": "^8.0.7",
    "playwright": "^1.60.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.1"
  }
}

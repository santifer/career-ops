    "yaml": "^2.3.4",
    "dotenv": "^16.3.1",
    "cli-table3": "^0.6.3",
    "ora": "^7.0.1",
    "inquirer": "^9.2.12",
    "node-fetch": "^3.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }

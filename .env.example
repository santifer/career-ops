# career-ops — Environment Variables
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env

# ── Gemini Integration (Issue #344) ─────────────────────────────────────────
# Required for: node gemini-eval.mjs "JD text here"
# Free API key: https://aistudio.google.com/apikey
# Free tier: 15 RPM / 1M tokens/day with gemini-2.0-flash (no billing needed)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional: Override default Gemini model ───────────────────────────────────
# Default: gemini-2.0-flash (free-tier, fast)
# Alternatives: gemini-1.5-flash, gemini-1.5-pro, gemini-2.0-flash-thinking-exp
# GEMINI_MODEL=gemini-2.0-flash

# ── Other integrations (add your own below) ──────────────────────────────────
# ANTHROPIC_API_KEY=your_anthropic_key_here   # For Claude-based workflows
# OPENAI_API_KEY=your_openai_key_here          # Future OpenAI integration

# ── AI Detection Gate (lib/ai-detection-gate.mjs) ───────────────────────────
# Three-detector ensemble: GPTZero + Originality.AI + Pangram (third detector,
# selected by council + dealbreaker adjudication 2026-05-19).
# If a key is missing, that detector is skipped (not blocking).
#
# GPTZero: https://gptzero.me/api — ~$0.01/call
# GPTZERO_API_KEY=
#
# Originality.AI: https://originality.ai/api — ~$0.01/call
# ORIGINALITY_API_KEY=
#
# Pangram: https://www.pangram.com/solutions/api — ~$0.02/call, $20/mo base
# UChicago BFI study (Aug 2025): lowest FPR of any tested detector (0.004%)
# Dealbreaker-selected over Sapling (28-95% FPR) and Copyleaks (5-6% FPR)
# PANGRAM_API_KEY=

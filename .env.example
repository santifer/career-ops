# career-ops — Environment Variables
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env

# ── Gemini Integration (Issue #344) ─────────────────────────────────────────
# Required for: node gemini-eval.mjs "JD text here"
# Free API key: https://aistudio.google.com/apikey
# Free tier: 15 RPM / 1M tokens/day with gemini-2.5-flash (no billing needed)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional: Override default Gemini model ───────────────────────────────────
# Default: gemini-2.5-flash (free-tier, fast)
# Alternatives: gemini-1.5-flash, gemini-1.5-pro, gemini-2.5-flash-thinking-exp
# GEMINI_MODEL=gemini-2.5-flash

# ── Other integrations (add your own below) ──────────────────────────────────
# ANTHROPIC_API_KEY=your_anthropic_key_here   # For Claude-based workflows
# OPENAI_API_KEY=your_openai_key_here          # Future OpenAI integration

# ── Supabase queue store (Step 2) ────────────────────────────────────────────
# Create the project in Sydney (ap-southeast-2), run:
#   supabase/migrations/202606060001_queue_store.sql
#
# Dashboard: sb_secret_ key — bypasses RLS (trusted local high-privilege client).
# Cron: publishable key + minted JWT with role=career_ops_cron (RLS enforced).
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_DASHBOARD_KEY=your_sb_secret_dashboard_key
# SUPABASE_CRON_PUBLISHABLE_KEY=your_publishable_or_anon_key
# SUPABASE_CRON_JWT=your_minted_jwt_with_role_career_ops_cron

# ── API-cron (Step 3a) — local testing only ──────────────────────────────────
# The GitHub Actions workflow mints the JWT at runtime from SUPABASE_CRON_SIGNING_KEY
# (held as an Environment secret). For local testing of the cron path, either:
#
#   Option A — set SUPABASE_CRON_JWT directly (mint locally first):
#     node mint-cron-jwt.mjs career_ops_signing_key_private.json --exp-seconds 600
#     Then paste the output as SUPABASE_CRON_JWT= in .env.
#
#   Option B — set CAREER_OPS_SIGNING_KEY (mirrors the CI env-key path):
#     CAREER_OPS_SIGNING_KEY="$(cat career_ops_signing_key_private.json)" \
#       node mint-cron-jwt.mjs --exp-seconds 600
#
# GitHub Actions secrets to create (Step 3a):
#   SUPABASE_URL                — repo or cron env secret
#   SUPABASE_CRON_PUBLISHABLE_KEY — repo or cron env secret
#   SUPABASE_CRON_SIGNING_KEY   — cron env secret, default-branch-only policy
#   PORTALS_YML                 — full contents of portals.yml (repo or cron env secret)
# CAREER_OPS_SIGNING_KEY=  # (never commit — local test only, mirrors the CI env-key path)


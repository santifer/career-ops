// Falls back to hardcoded defaults if the file or key is missing.
const PROFILE_PATH = join(__dirname, 'config', 'profile.yml');
function loadProfileAutosubmit() {
  const defaults = {
    country: 'United States', city: 'Lewisville', zip: '75067', state: 'Texas',
    work_authorized: 'Yes', requires_sponsorship: 'No',
    visa_status: 'US Citizen or Permanent Resident',
  };
  try {
    const raw = readFileSync(PROFILE_PATH, 'utf8');
    // Extract the autosubmit: block (everything indented under it)
    const blockMatch = raw.match(/^autosubmit:\s*\n((?:[ \t]+[^\n]+\n?)*)/m);
    if (!blockMatch) return defaults;
    const block = blockMatch[1];
    const get = (key) => {
      const m = block.match(new RegExp(`^[ \\t]+${key}:\\s*"?([^"\\n]+)"?`, 'm'));
      return m ? m[1].trim() : null;
    };
    return {
      country:               get('country')              || defaults.country,
      city:                  get('city')                 || defaults.city,
      zip:                   get('zip')                  || defaults.zip,
      state:                 get('state')                || defaults.state,
      work_authorized:       get('work_authorized')      || defaults.work_authorized,
      requires_sponsorship:  get('requires_sponsorship') || defaults.requires_sponsorship,
      visa_status:           get('visa_status')          || defaults.visa_status,
    };
  } catch { return defaults; }
}

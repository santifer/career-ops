/**
 * Load ATS confirmation patterns from data/ats-confirmation-patterns.json.
 * Returns the platform-specific block, or the fallback if ATS is unknown.
 */
function loadAtsPatterns(ats) {
  try {
    const raw = JSON.parse(readFileSync(ATS_PATTERNS_PATH, 'utf8'));
    return raw.platforms?.[ats] ?? raw.fallback;
  } catch {
    // Hardcoded fallback if file is missing — keeps the gate functional
    return {
      fresh_submission: {
        url_patterns: ['/confirmation', '/success', '/thank-you', '/submitted', '/applied', '/thanks'],
        text_patterns: ['application submitted', 'thank you.*appl', 'we.*received.*application', 'successfully submitted'],
      },
      already_applied: {
        url_patterns: [],
        text_patterns: ['already applied', "you've already applied", 'previously submitted', 'you applied on'],
      },
    };
  }
}

/**
 * Test a list of regex pattern strings against a target string.
 * Returns { matched: bool, pattern: string|null } — the first pattern that matched.
 */
function matchPatterns(patterns, target) {
  for (const p of (patterns ?? [])) {
    try {
      if (new RegExp(p, 'i').test(target)) return { matched: true, pattern: p };
    } catch { /* skip malformed regex */ }
  }
  return { matched: false, pattern: null };
}

/**
 * Append a hit record to data/ats-pattern-hits.json so we can see
 * which patterns fired over time and tune them without guessing.
 */
function recordPatternHit(ats, outcome, patternType, pattern, url) {
  try {
    let hits = [];
    if (existsSync(PATTERN_HITS_PATH)) {
      hits = JSON.parse(readFileSync(PATTERN_HITS_PATH, 'utf8'));
    }
    hits.push({ ts: new Date().toISOString(), ats, outcome, patternType, pattern, url });
    // Keep last 500 hits — enough history without bloat
    if (hits.length > 500) hits = hits.slice(-500);
    const tmp = PATTERN_HITS_PATH + '.tmp';
    writeFileSync(tmp, JSON.stringify(hits, null, 2));
    renameSync(tmp, PATTERN_HITS_PATH);
  } catch { /* non-fatal */ }
}

/** Resolve a dotted key like "profile.first_name" from a nested object */
function resolvePath(obj, dotPath) {
  return dotPath.split('.').reduce((cur, k) => (cur != null ? cur[k] : undefined), obj);
}

/** Fuzzy-match a field label against ats_field_map keys */
function matchLabel(label, fieldMap) {
  if (!label) return null;
  const normalized = label.trim().toLowerCase().replace(/[*:]+$/, '').trim();
  if (fieldMap[normalized]) return fieldMap[normalized];
  // partial match
  for (const [key, val] of Object.entries(fieldMap)) {
    if (normalized.includes(key) || key.includes(normalized)) return val;
  }
  return null;
}

/** Detect ATS from URL */
function detectATS(url) {
  if (/greenhouse\.io/i.test(url))                          return 'greenhouse';
  if (/[?&]gh_jid=/i.test(url))                             return 'greenhouse'; // TD-22: marketing wrapper carrying a Greenhouse job id
  if (/stripe\.com\/jobs\/listing\//i.test(url))            return 'greenhouse'; // TD-22: Stripe listing page wraps a Greenhouse board
  if (/lever\.co/i.test(url))                               return 'lever';
  if (/ashbyhq\.com/i.test(url))                            return 'ashby';
  if (/myworkdayjobs\.com/i.test(url))                      return 'workday';
  if (/linkedin\.com\/jobs/i.test(url))                     return 'linkedin';
  if (/indeed\.com|smartapply\.indeed\.com/i.test(url))     return 'indeed';
  if (/theladders\.com/i.test(url))                         return 'theladders';
  if (/hiringcafe\.com/i.test(url))                         return 'hiringcafe';
  if (/icims\.com/i.test(url))                              return 'icims';
  return 'unknown';
}

/**
 * Generic subdomain prefixes that don't identify a company.
 * When the first hostname segment is one of these, fall back to the second segment.
 * e.g. careers.toasttab.com → "toasttab" not "careers"
 * TD-13 2026-05-19
 */
const GENERIC_HOST_PREFIXES = new Set([
  'careers', 'jobs', 'apply', 'work', 'hire', 'hiring',
  'talent', 'recruit', 'recruiting', 'boards',
]);

/**
 * Hostname slug → Greenhouse board token, for the cases where they differ.
 * Most of the time the board token IS the hostname SLD (databricks.com → "databricks").
 * Add an entry here only when the URL-verification gate logs a 404 for a guessed token.
 * TD-22 2026-05-24.
 */
const GREENHOUSE_BOARD_ALIASES = {
  // 'examplehost': 'actual-greenhouse-board-token',
};

/** Derive the Greenhouse board token from a marketing-wrapper URL's hostname. */
function greenhouseBoardFromUrl(url) {
  try {
    const host = new URL(url).hostname.replace(/^www\./, '');
    const parts = host.split('.');
    const slug = GENERIC_HOST_PREFIXES.has(parts[0]) ? (parts[1] ?? parts[0]) : parts[0];
    return GREENHOUSE_BOARD_ALIASES[slug] || slug;
  } catch {
    return null;
  }
}

/**
 * TD-22 (2026-05-24): Greenhouse jobs were being injected as company marketing-site
 * URLs (stripe.com/jobs/listing/..., databricks.com/...?gh_jid=...) that carry the
 * job id but render a marketing page with NO application form. detectATS saw
 * 'unknown', no platform handler ran, and AutoSubmit stalled at 'no-submit-button'
 * (8 of 15 blocked cards in the 2026-05-23 bat run). This rewrites such wrappers to
 * the canonical Greenhouse board form URL. Pure function — unit-tested without a browser.
 */
function canonicalizeApplyUrl(url) {
  try {
    // Already a canonical board URL — leave it untouched
    if (/job-boards\.greenhouse\.io\/[^/]+\/jobs\/\d+/i.test(url)) return url;
    // Legacy host: boards.greenhouse.io/{board}/jobs/{id} → job-boards.greenhouse.io
    const legacy = url.match(/boards\.greenhouse\.io\/([^/?#]+)\/jobs\/(\d+)/i);
    if (legacy) return `https://job-boards.greenhouse.io/${legacy[1]}/jobs/${legacy[2]}`;
    // Stripe: stripe.com/jobs/listing/{slug}/{id} → Greenhouse board "stripe"
    const stripeM = url.match(/stripe\.com\/jobs\/listing\/[^/]+\/(\d+)/i);
    if (stripeM) return `https://job-boards.greenhouse.io/stripe/jobs/${stripeM[1]}`;
    // Generic marketing wrapper carrying ?gh_jid={id}
    const ghJid = url.match(/[?&]gh_jid=(\d+)/i);
    if (ghJid) {
      const board = greenhouseBoardFromUrl(url);
      if (board) return `https://job-boards.greenhouse.io/${board}/jobs/${ghJid[1]}`;
    }
    return url;
  } catch {
    return url;
  }
}

